# PostgreSQL connection string (Neon)
DATABASE_URL=

# Server port (Render sets PORT automatically; EXPRESS_PORT is a fallback for local dev)
PORT=
EXPRESS_PORT=3001

# Environment: development | production
NODE_ENV=development

# Allowed CORS origin for the frontend (e.g. http://localhost:5173 or https://xotiji.app)
FRONTEND_URL=

# JWT secret — used for signing and verifying auth tokens (use a long random string)
JWT_SECRET=

# OpenAI API key — used for AI suggestions and package composer
OPENAI_API_KEY=

# fal.ai API key — used for Space Selfie (flux-pro/kontext)
FAL_API_KEY=

# Cloudflare R2 credentials — xotiji-shares bucket
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=xotiji-shares
R2_ENDPOINT=
R2_PUBLIC_URL=
