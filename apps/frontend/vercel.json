{
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/s/(.*)",
      "dest": "https://hatirla-base.onrender.com/api/share/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
